{
  "name": "risking",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "cd frontend && yarn dev",
    "dev:backend": "cd backend && yarn start:dev",
    "dev": "concurrently \"yarn dev:frontend\" \"yarn dev:backend\"",
    "install:all": "yarn install && cd frontend && yarn install && cd ../backend && yarn install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
